{
  "name": "@housepoints/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build -w @housepoints/contracts && npm run build -w @housepoints/db && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "node -e \"console.log('No API lint rules configured yet')\""
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/rate-limit": "^11.0.0",
    "@housepoints/contracts": "*",
    "@housepoints/db": "*",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "pino": "^10.3.1",
    "pino-seq": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}

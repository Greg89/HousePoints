generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MEMBER
  ADMIN
  OWNER
}

enum Trait {
  LEADERSHIP
  OWNERSHIP
  COLLABORATION
  MENTORSHIP
  TECHNICAL_EXCELLENCE
  PROBLEM_SOLVING
  INNOVATION
  KNOWLEDGE_SHARING
  COMMUNICATION
  CUSTOMER_FOCUS
  RELIABILITY
  INITIATIVE
  PROCESS_IMPROVEMENT
  TEAM_SUPPORT
  ACCOUNTABILITY
  ADAPTABILITY
  POSITIVE_INFLUENCE
  ABOVE_AND_BEYOND
  CULTURE_CHAMPION
  UNSUNG_HERO
}

enum AuditEventType {
  INVITE_CREATED
  INVITE_USED
  POINT_DELETED
  USER_HOUSE_ASSIGNED
}

model Organization {
  id           String             @id @default(cuid())
  name         String
  slug         String             @unique
  users        User[]
  houses       House[]
  transactions PointTransaction[]
  invites      OrgInvite[]
  seasons      Season[]
  auditEvents  AuditEvent[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model OrgInvite {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tokenHash      String    @unique          // SHA-256 of the raw token — never store raw
  createdById    String
  createdBy      User      @relation("CreatedInvites", fields: [createdById], references: [id], onDelete: Restrict)
  expiresAt      DateTime
  usedAt         DateTime?
  usedById       String?
  usedBy         User?     @relation("UsedInvites", fields: [usedById], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now())

  @@index([organizationId])
  @@index([tokenHash])
}

model House {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  color          String             @default("#7c3aed")
  description    String?
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  users        User[]
  transactions PointTransaction[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model User {
  id                   String             @id @default(cuid())
  auth0Sub             String             @unique
  email                String?            @unique
  displayName          String
  role                 Role               @default(MEMBER)
  organizationId       String?
  organization         Organization?      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  houseId              String?
  house                House?             @relation(fields: [houseId], references: [id], onDelete: Restrict)
  pointTransactions    PointTransaction[] @relation("ActorTransactions")
  receivedTransactions PointTransaction[] @relation("PointsReceived")
  deletedPointTransactions PointTransaction[] @relation("DeletedPointTransactions")
  createdInvites       OrgInvite[]        @relation("CreatedInvites")
  usedInvite           OrgInvite[]        @relation("UsedInvites")
  createdSeasons       Season[]           @relation("CreatedSeasons")
  auditEvents          AuditEvent[]       @relation("AuditEventActor")
  authIdentities        AuthIdentity[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([organizationId])
  @@index([houseId])
}

model AuthIdentity {
  id              String   @id @default(cuid())
  userId          String
  providerSubject String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model Season {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  startsAt       DateTime
  endsAt         DateTime?
  isActive       Boolean            @default(false)
  createdById    String?
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?              @relation("CreatedSeasons", fields: [createdById], references: [id], onDelete: SetNull)
  transactions   PointTransaction[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId, isActive])
  @@index([organizationId, startsAt])
  @@index([createdById])
}

model PointTransaction {
  id             String   @id @default(cuid())
  organizationId String
  seasonId       String
  actorUserId    String
  targetUserId   String?
  targetHouseId  String
  delta          Int
  reason         String
  trait          Trait?
  deletedAt      DateTime?
  deletedByUserId String?
  deletionReason String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  season       Season       @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  actor        User         @relation("ActorTransactions", fields: [actorUserId], references: [id], onDelete: Restrict)
  targetUser   User?        @relation("PointsReceived", fields: [targetUserId], references: [id], onDelete: SetNull)
  deletedBy    User?        @relation("DeletedPointTransactions", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  targetHouse  House        @relation(fields: [targetHouseId], references: [id], onDelete: Restrict)

  @@index([organizationId, createdAt])
  @@index([organizationId, seasonId, createdAt])
  @@index([organizationId, deletedAt])
  @@index([targetHouseId, createdAt])
  @@index([targetHouseId, seasonId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([targetUserId, seasonId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([deletedByUserId])
}

model AuditEvent {
  id             String         @id @default(cuid())
  organizationId String
  actorUserId    String?
  eventType      AuditEventType
  summary        String
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation("AuditEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId])
}
